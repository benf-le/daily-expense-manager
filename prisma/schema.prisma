generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  role        String    @default("USER")
  budgetLimit Float     @default(5000000)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  incomes     Income[]
  outcomes    Outcome[]
}

model Income {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  description String   @default("")
  date        DateTime
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Outcome {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String
  description String   @default("")
  date        DateTime
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
